rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isBackoffice() {
      return isSignedIn()
        && (
          request.auth.token.role == "admin"
          || request.auth.token.role == "recruiter"
          || request.auth.token.role == "hr"
        );
    }

    match /cvs/{candidateId}/{fileName} {
      allow write: if isSignedIn()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType == "application/pdf";

      // TODO (producción): reemplazar por la línea de abajo una vez que los usuarios
      // del backoffice tengan el custom claim role:'recruiter'|'admin'|'hr' seteado
      // via Admin SDK (ej: en un onCreate trigger o al asignar rol desde el panel).
      //   allow read: if isBackoffice() || (isSignedIn() && request.auth.uid == candidateId);
      allow read: if isSignedIn();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}