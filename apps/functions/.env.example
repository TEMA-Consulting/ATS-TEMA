# OAuth. Usar credenciales de desarrollo; no versionar valores reales.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GMAIL_MOCK=true

# Calendar
CALENDAR_WEBHOOK_URL=
CALENDAR_WEBHOOK_SECRET=

# CORS y enlaces públicos
ALLOWED_ORIGIN=http://localhost:3000
OFFER_PUBLIC_BASE_URL=http://localhost:3000

# Parsing de CV
CV_PARSER_MODEL=gemini-2.5-flash
CV_PARSING_USE_MOCK=true
CV_PARSING_FORCE_REAL_AI=false
CV_PARSING_FORCE_REPROCESS=false
VERTEX_LOCATION=us-central1
GCP_PROJECT=

# Secretos: usar valores locales solo con emuladores.
# En producción configurarlos mediante Firebase Secret Manager.
OAUTH_ENCRYPTION_KEY=
