# Firebase Web SDK. Estos valores identifican la app, no son secretos.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FUNCTIONS_REGION=us-central1

# Desarrollo local
NEXT_PUBLIC_USE_EMULATORS=true
NEXT_PUBLIC_FUNCTIONS_EMULATOR_PORT=5001

# Google OAuth
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
NEXT_PUBLIC_GMAIL_REDIRECT_URI=http://localhost:3000
NEXT_PUBLIC_CALENDAR_REDIRECT_URI=http://localhost:3000

# URL pública usada para enlaces absolutos cuando corresponda.
NEXT_PUBLIC_APP_URL=http://localhost:3000
